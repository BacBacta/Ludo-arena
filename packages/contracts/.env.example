# Deployment (script/deploy.ts). NEVER commit a real key.
# Target network: localhost | sepolia | celo-sepolia | alfajores
NETWORK=sepolia
# Funded deployer key on the target network (faucet first)
DEPLOYER_PRIVATE_KEY=
# Server arbiter key's ADDRESS (defaults to the deployer address)
ARBITER_ADDRESS=
# Rake recipient (defaults to the deployer address)
TREASURY_ADDRESS=
# Basis points, 900 = 9% (max 1000, enforced by the contract)
RAKE_BPS=900
# Existing stablecoin address; leave empty to deploy TestUSD (testnets without cUSD)
STABLECOIN=
# RPC overrides (sensible public defaults built in)
SEPOLIA_RPC=
CELO_SEPOLIA_RPC=
ALFAJORES_RPC=
