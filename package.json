{
  "name": "ludo-arena",
  "private": true,
  "version": "0.1.0",
  "description": "Ludo Arena \u2014 Ludo Mini App for MiniPay (Celo). Monorepo: game engine, real-time server, frontend, smart contracts.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "simulate": "npm run simulate -w packages/game-engine",
    "sim:engine": "tsx sim/engine.ts",
    "sim:contracts": "cd packages/contracts && forge test",
    "sim": "npm run sim:engine && npm run sim:contracts",
    "sim:flow": "DIE_SETTLE_MS=0 tsx sim/flow.ts",
    "sim:rational": "node simulation/rational.mjs",
    "sim:chaos": "node simulation/chaos.mjs",
    "sim:chaos-net": "node simulation/chaos-net.mjs",
    "sim:replay": "tsx simulation/replay.mjs",
    "sim:all": "npm run sim:engine && npm run sim:contracts && npm run sim:flow"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.63.0"
  }
}
