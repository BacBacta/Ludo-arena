{
  "name": "ludo-arena",
  "private": true,
  "version": "0.1.0",
  "description": "Ludo Arena — Ludo Mini App for MiniPay (Celo). Monorepo: game engine, real-time server, frontend, smart contracts.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "simulate": "npm run simulate -w packages/game-engine"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.63.0"
  }
}
