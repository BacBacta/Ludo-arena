# WebSocket port
PORT=8787
# Persistence (E2.1). Leave empty for in-memory dev mode (no restart survival).
# Local infra: `docker compose up -d` at the repo root.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://ludo:ludo@localhost:5432/ludo
# Arbiter private key (on-chain settlement) — NEVER a real key in the repo
ARBITER_PRIVATE_KEY=
# Celo RPCs
ALFAJORES_RPC=https://alfajores-forno.celo-testnet.org
CELO_RPC=https://forno.celo.org
# LudoEscrow contract address (one per network, see packages/contracts/deployments.json)
ESCROW_ADDRESS=
