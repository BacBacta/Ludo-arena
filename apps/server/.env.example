# WebSocket port
PORT=8787
# Persistence (E2.1). Leave empty for in-memory dev mode (no restart survival).
# Local infra: `docker compose up -d` at the repo root.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://ludo:ludo@localhost:5432/ludo
# On-chain settlement (E3.3). Leave ARBITER_PRIVATE_KEY empty to disable.
# Arbiter private key — NEVER a real key in the repo. Must be the address set as
# `arbiter` at deployment (see packages/contracts/deployments.json).
ARBITER_PRIVATE_KEY=
# Settlement target chain: celo | celo-sepolia (default celo-sepolia)
CHAIN=celo-sepolia
# Optional RPC override for settlement (defaults to the chain's public RPC)
SETTLEMENT_RPC=
# LudoEscrow address override; by default resolved from deployments.json by chainId
ESCROW_ADDRESS=
